# ============================================
# Artist Push — Environment Variables
# ============================================
# Copy this file to .env and fill in your real Stripe keys
#
# Get your keys at: https://dashboard.stripe.com/apikeys

# Stripe Secret Key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Stripe Publishable Key (starts with pk_test_ or pk_live_)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Stripe Webhook Secret (starts with whsec_)
# Get this from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Server port
PORT=3000

# Your domain (used for CORS and webhook URLs)
DOMAIN=http://localhost:3000

# Allowed CORS origins (comma-separated)
# In production: https://artistpush.net,https://www.artistpush.net
ALLOWED_ORIGINS=http://localhost:3000
